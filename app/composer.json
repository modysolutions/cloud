{
    "name": "app/wp",
    "version": "0.0.1",
    "description": "WordPress Sites",
    "autoload": {
        "psr-4": {
            "App\\": "web/themes/theme/app"
        }
    },
    "authors": [
        {
            "name": "Mody Solutions"
        }
    ],
    "repositories": {
        "wpackagist": {
            "type": "composer",
            "url": "https://wpackagist.org",
            "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
        }
    },
    "require": {
        "wpackagist-plugin/wordpress-seo": "26.8",
        "wpackagist-plugin/ewww-image-optimizer": "8.3.1",
        "wpackagist-plugin/user-role-editor": "4.64.6",
        "wpackagist-plugin/w3-total-cache": "2.9.1",
        "wpackagist-plugin/redirection": "5.6.1",
        "wpackagist-plugin/smart-phone-field-for-gravity-forms": "2.2.0",
        "wpackagist-plugin/ultimate-addons-for-gutenberg": "2.19.26",
        "timber/timber": "^2.0",
        "wpackagist-theme/twentytwentyfive": "^1.5"
    },
    "require-dev": {
        "wpackagist-plugin/query-monitor": "3.20.2",
        "roave/security-advisories": "dev-latest",
        "laravel/pint": "1.18"
    },
    "extra": {
        "installer-paths": {
            "web/plugins/{$name}/": ["type:wordpress-plugin"],
            "web/themes/{$name}/": ["type:wordpress-theme"]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
