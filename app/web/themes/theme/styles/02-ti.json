{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"title": "T.I.",
	"settings": {
		"color": {
			"palette": [
				{
					"color": "#5D3019",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#000000",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#432312",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "#5D3019",
					"name": "Accent 01",
					"slug": "accent-01"
				},
				{
					"color": "#A6572E",
					"name": "Accent 02",
					"slug": "accent-02"
				},
				{
					"color": "#B89F41",
					"name": "Accent 03",
					"slug": "accent-03"
				},
				{
					"color": "#C59176",
					"name": "Accent 04",
					"slug": "accent-04"
				},
				{
					"color": "#ECE9E7",
					"name": "Brown 50",
					"slug": "brown-50"
				},
				{
					"color": "#C5BBB6",
					"name": "Brown 100",
					"slug": "brown-100"
				},
				{
					"color": "#A99A92",
					"name": "Brown 200",
					"slug": "brown-200"
				},
				{
					"color": "#816C60",
					"name": "Brown 300",
					"slug": "brown-300"
				},
				{
					"color": "#694F41",
					"name": "Brown 400",
					"slug": "brown-400"
				},
				{
					"color": "#432312",
					"name": "Brown 500",
					"slug": "brown-500"
				},
				{
					"color": "#3D2010",
					"name": "Brown 600",
					"slug": "brown-600"
				},
				{
					"color": "#30190D",
					"name": "Brown 700",
					"slug": "brown-700"
				},
				{
					"color": "#25130A",
					"name": "Brown 800",
					"slug": "brown-800"
				},
				{
					"color": "#1C0F08",
					"name": "Brown 900",
					"slug": "brown-900"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"name": "Bitter",
					"slug": "bitter",
					"fontFamily": "Bitter, serif",
					"fontFace": [
						{
							"fontFamily": "Bitter",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/bitter/bitter-v19-latin-regular.woff2"
							]
						},
						{
							"fontFamily": "Bitter",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/bitter/bitter-v19-latin-700.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.9rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.2rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.8rem",
						"min": "1.6rem"
					},
					"name": "Large",
					"size": "1.6rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2.2rem",
						"min": "1.8em"
					},
					"name": "Extra Large",
					"size": "1.8rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "2.8rem",
						"min": "2rem"
					},
					"name": "Extra Extra Large",
					"size": "2rem",
					"slug": "xx-large"
				}
			]
		}
	},
	"styles": {
		"color": {
			"text": "var:preset|color|accent-04"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|bitter",
			"fontSize": "var:preset|font-size|medium",
			"letterSpacing": "-0.01em",
			"lineHeight": "1.6"
		},
		"blocks": {
			"core/button": {
				"border": {
					"color": "var:preset|color|secondary"
				},
				"shadow": "var:preset|shadow|natural",
				"spacing": {
					"padding": {
						"bottom": "0.6rem",
						"left": "1.6rem",
						"right": "1.6rem",
						"top": "0.6rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|bitter"
				},
				"variations": {
					"outline": {
						"shadow": "none",
						"spacing": {
							"padding": {
								"bottom": "0.6rem",
								"left": "1.6rem",
								"right": "1.6rem",
								"top": "0.6rem"
							}
						}
					}
				}
			},
			"core/list": {
				"typography": {
					"lineHeight": "1.3"
				}
			},
			"core/loginout": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontWeight": "300"
				}
			},
			"core/post-title": {
				"color": {
					"text":  "var:preset|color|accent-03"
				},
				"elements": {
					"link": {
						"color": {
							"text": "currentColor"
						}
					}
				}
			},
			"core/pullquote": {
				"color": {
					"text": "var:preset|color|accent-03"
				},
				"elements": {
					"link": {
						"color": {
							"text": "currentColor"
						}
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|bitter",
					"fontWeight": "500",
					"lineHeight": "1"
				}
			},
			"core/quote": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"core/query-pagination": {
				"typography": {
					"fontWeight": "300"
				}
			},
			"core/query-title": {
				"color": {
					"text": "var:preset|color|accent-03"
				},
				"elements": {
					"link": {
						"color": {
							"text": "currentColor"
						}
					}
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|bitter",
					"fontWeight": "600",
					"letterSpacing": "2.4px",
					"textTransform": "uppercase"
				}
			}
		},
		"elements": {
			"button": {
				"color": {
					"background": "var:preset|color|secondary",
					"text": "var:preset|color|brown-50"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"letterSpacing": "0px"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				}
			},
			"heading": {
				"color": {
					"text": "var:preset|color|accent-03"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|bitter",
					"fontWeight": "500",
					"letterSpacing": "-0.02em",
					"lineHeight": "1.02"
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				}
			}
		},
		"variations": {
			"section-4": {
				"color": {
					"text": "var:preset|color|accent-02"
				},
				"elements": {
					"button": {
						":hover": {
							"color": {
								"background": "color-mix(in srgb, var(--wp--preset--color--accent-02) 85%, transparent)"
							}
						}
					},
					"heading": {
						"color": {
							"text": "currentColor"
						}
					},
					"link": {
						"color": {
							"text": "currentColor"
						}
					}
				}
			},
			"section-5": {
				"color": {
					"text": "var:preset|color|brown-50"
				},
				"elements": {
					"button": {
						":hover": {
							"color": {
								"background": "color-mix(in srgb, var(--wp--preset--color--brown-50) 85%, transparent)"
							}
						}
					},
					"heading": {
						"color": {
							"text": "var:preset|color|brown-50"
						}
					},
					"link": {
						"color": {
							"text": "currentColor"
						}
					}
				}
			}
		}
	}
}
