#!/bin/bash

ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"
./bin/log "INFO" "Checking .env file exists in ${ENV_FILE}"
if [ ! -f "${ENV_FILE}" ]; then
  ./bin/log "ERROR" "No .env file found"
  exit 1;
fi
source "${ENV_FILE}";

./bin/certs
mkdir -p "${ROOT_DIR}/app/logs" && \
touch "${ROOT_DIR}/app/logs/xdebug.log" && \
touch "${ROOT_DIR}/app/logs/debug.log" && \
chmod 666 "${ROOT_DIR}/app/logs/xdebug.log" "${ROOT_DIR}/app/logs/debug.log" && \
docker compose up -d --build --force-recreate --remove-orphans && \
./bin/version "${WORDPRESS_VERSION}" --no-backup && \
./bin/composer config http-basic.plugins.tamarindintelligence.com "${SATISPRESS_KEY}" "satispress" && \
./bin/composer install && \
./bin/wp core install --url="${HOST_NAME}" --title="${SITE_TITLE}" --admin_user="${SITE_ADMIN}"  --admin_email="${SITE_ADMIN}" --admin_password="${SITE_ADMIN_PASSWD}" --skip-email && \
./bin/test && \
./bin/log "SUCCESS" "Installation completed successfully"