#!/bin/bash

ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"
./bin/log "INFO" "Checking .env file exists in ${ENV_FILE}"
if [ ! -f "${ENV_FILE}" ]; then
  ./bin/log "ERROR" "No .env file found"
  exit 1;
fi
source "${ENV_FILE}";

docker compose up -d --force-recreate --remove-orphans && \
./bin/log "SUCCESS" "Site started at https://${HOST_NAME:-default.local}"
