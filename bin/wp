#!/bin/bash
ROOT_DIR=$(pwd)
ENV_FILE="${ROOT_DIR}/.env"

if [ ! -f $ENV_FILE ]; then
  ./bin/log "ERROR" "No .env file found"
  exit 1;
fi

source "${ENV_FILE}"
ALIAS="${SITE_SLUG}"
CONTAINER_NAME="${CONTAINER_PREFIX}app"

if [ -t 0 ]; then
    TTY_FLAG="-it"
else
    TTY_FLAG="-i"
fi
./bin/log "INFO" "wp $* in container $CONTAINER_NAME"
docker exec $TTY_FLAG -u www-data "$CONTAINER_NAME" wp "$@"
