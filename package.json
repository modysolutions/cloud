  "scripts": {
    "build": "pnpm run lint:js && pnpm run lint:scss && pnpm run build:theme",
    "build:theme": "wp-scripts build --webpack-src-dir=src --output-path=app/dist --config=config/webpack/webpack.config.js",
    "start": "pnpm run lint:js && pnpm run lint:scss && pnpm run start:theme",
    "start:theme": "wp-scripts start --webpack-src-dir=src --output-path=app/dist --config=config/webpack/webpack.config.js",
    "lint:js": "eslint 'src/**/*.js'",
    "lint:js:fix": "eslint 'src/**/*.js' --fix",
    "lint:scss": "stylelint 'src/**/*.scss' --fix",
    "lint:scss:ci": "stylelint 'src/**/*.scss'"
